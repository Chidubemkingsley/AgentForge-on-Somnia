# ── Network ──
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network
SOMNIA_CHAIN_ID=50312
CORS_ORIGIN=http://localhost:3000
PORT=5000
NODE_ENV=development

# ── AI (Groq llama-3.1-8b-instant) ──
GROQ_API_KEY=gsk_...  # Get a free key at https://console.groq.com

# ── Auth / Wallet (Privy) ──
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/agentkyro

# ── Media (Cloudinary) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (optional notifications) ──
EMAIL_HOST=your_email_host
EMAIL_PORT=587
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_pass

# ── USDC on Somnia Testnet ──
USDC_CONTRACT_ADDRESS=0x5D4266f4DD721c1cD8367FEb23E4940d17C83C93
USDC_DECIMALS=6

# ── Role Wallets (EVM private keys) ──
# Platform wallet — receives platform fees, signs releases
PLATFORM_PRIVATE_KEY=0x...
# AI Verifier wallet — holds Approver role, signs milestone approvals
VERIFIER_PRIVATE_KEY=0x...
# AI Arbiter wallet — holds Dispute Resolver role, resolves disputes
ARBITER_PRIVATE_KEY=0x...

# ── Escrow Contract (deployed on Somnia) ──
ESCROW_CONTRACT_ADDRESS=0x...

# ── Agent EVM Wallets ──
SOMNIA_ORACLE_PRIVATE_KEY=0x...
WEB_INTEL_PRIVATE_KEY=0x...
WEB_INTEL_V2_PRIVATE_KEY=0x...
ANALYSIS_AGENT_PRIVATE_KEY=0x...
REPORT_AGENT_PRIVATE_KEY=0x...

# ── Ports ──
REGISTRY_PORT=4000
SOMNIA_ORACLE_PORT=4001
WEB_INTEL_PORT=4002
WEB_INTEL_V2_PORT=4003
ANALYSIS_AGENT_PORT=4004
REPORT_AGENT_PORT=4005
ORCHESTRATOR_PORT=5000

# ── Registry ──
REGISTRY_URL=http://localhost:4000
DEFAULT_BUDGET=1.0

# ── Self URLs (update when deploying) ──
ORCHESTRATOR_SELF_URL=http://localhost:5000
SOMNIA_ORACLE_SELF_URL=http://localhost:4001
WEB_INTEL_SELF_URL=http://localhost:4002
WEB_INTEL_V2_SELF_URL=http://localhost:4003
ANALYSIS_AGENT_SELF_URL=http://localhost:4004
REPORT_AGENT_SELF_URL=http://localhost:4005

# ── Plan approval timeout (ms). 0 = auto-approve immediately ──
PLAN_APPROVAL_TIMEOUT_MS=60000
