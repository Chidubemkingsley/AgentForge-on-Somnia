# ── Network ──
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network
SOMNIA_CHAIN_ID=50312
CORS_ORIGIN=http://localhost:3000
PORT=5000
NODE_ENV=development

# ── AI (Groq) ──
GROQ_API_KEY=

# ── Auth / Wallet (Privy) ──
VITE_PRIVY_APP_ID=

# ── USDC on Somnia Testnet ──
USDC_CONTRACT_ADDRESS=0x214e2316EAEeE24c1dc5d8433329fFC7544DA331
USDC_DECIMALS=6

# ── Role Wallets (EVM private keys) ──
PLATFORM_PRIVATE_KEY=
VERIFIER_PRIVATE_KEY=
ARBITER_PRIVATE_KEY=

# ── Escrow Contract (deployed on Somnia) ──
ESCROW_CONTRACT_ADDRESS=0x553091386a1Cf46EA616F9Ba6f7Bf025eb5c2D41

# ── Agent EVM Wallets (generate random keys for each) ──
SOMNIA_ORACLE_PRIVATE_KEY=
WEB_INTEL_PRIVATE_KEY=
WEB_INTEL_V2_PRIVATE_KEY=
ANALYSIS_AGENT_PRIVATE_KEY=
REPORT_AGENT_PRIVATE_KEY=

# ── Ports ──
REGISTRY_PORT=4000
SOMNIA_ORACLE_PORT=4001
WEB_INTEL_PORT=4002
WEB_INTEL_V2_PORT=4003
ANALYSIS_AGENT_PORT=4004
REPORT_AGENT_PORT=4005
ORCHESTRATOR_PORT=3000

# ── Registry ──
REGISTRY_URL=http://localhost:4000
DEFAULT_BUDGET=1.0

# ── Self URLs (update when deploying) ──
ORCHESTRATOR_SELF_URL=http://localhost:5000
SOMNIA_ORACLE_SELF_URL=http://localhost:4001
WEB_INTEL_SELF_URL=http://localhost:4002
WEB_INTEL_V2_SELF_URL=http://localhost:4003
ANALYSIS_AGENT_SELF_URL=http://localhost:4004
REPORT_AGENT_SELF_URL=http://localhost:4005

# ── Plan approval timeout (ms). 0 = auto-approve immediately ──
PLAN_APPROVAL_TIMEOUT_MS=60000
